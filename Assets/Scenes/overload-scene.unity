  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Listen Carefully.\nI  will explain how to end the experience \nBut, in
    order to understand what is happening\nand why you're here,\nYou need to ask
    yourself one question first.\nWhat do you notice?\nEverything around you\nThe
    lights, the sounds - all of it,\nThey only exist because you are telling them
    to.\nWhat are you in control of right now?\nThere is no correct answer,\nBut
    the answer is simple.\nHow aware are you of what you're doing?\nAre you aware
    of what you're experiencing?\nBecause it will all stop\nThe moment you choose
    to stop too.\nWhat is it that you aren't doing?\nAs long as you stay here,\nYou
    will be able to stop this.\nStay here.\nTHE MORE YOU LOOK\nThe less you see\nDo
    you see it now?\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
